# Optional Google Maps embedded basemap.
# This is public in the browser and is bundled during `next build`.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=

# Optional server-side LLM configuration for the dashboard `Default` provider.
# `Default` is locked in the UI; alternative providers can be configured in the dashboard.
# Keep the real API key in `.env.local` for local dev or `.env` for Docker Compose.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
